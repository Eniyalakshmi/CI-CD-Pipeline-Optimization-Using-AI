pipeline {
    agent any

    stages {

        stage('Clone Repo') {
            steps {
                git 'https://github.com/Eniyalakshmi/CI-CD-Pipeline-Optimization-Using-AI.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'pip install -r requirements.txt'
            }
        }

        stage('Code Optimization') {
            steps {
                sh 'python optimizer.py'
            }
        }

        stage('Run Tests') {
            steps {
                sh 'pytest test_app.py'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying Application...'
                sh 'python app.py'
            }
        }

    }
}
